# ────────────────────────────────────────────────────────────────────────────
# Discord Bot Configuration
# ────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here

# Required: Your bot's Application ID (found in Developer Portal → General)
DISCORD_CLIENT_ID=your-client-id-here

# Optional: Restrict slash command registration to a single guild (faster for dev).
# Leave blank to register globally (can take up to 1 hour to propagate).
DISCORD_GUILD_ID=

# ────────────────────────────────────────────────────────────────────────────
# Upload Limits
# ────────────────────────────────────────────────────────────────────────────

# Maximum ZIP file size in megabytes (default: 100)
MAX_ZIP_SIZE_MB=100

# ────────────────────────────────────────────────────────────────────────────
# Storage & Logging
# ────────────────────────────────────────────────────────────────────────────

# Temporary directory for ZIP extraction (created automatically)
TEMP_DIR=./tmp

# Log level: error | warn | info | debug | silly
LOG_LEVEL=info

# Directory for rotating log files (created automatically)
LOG_DIR=./logs

# ────────────────────────────────────────────────────────────────────────────
# Queue Defaults (users can override per-session via /emoji-upload settings)
# ────────────────────────────────────────────────────────────────────────────

# Parallel upload concurrency (1-10, default: 2)
DEFAULT_CONCURRENCY=2

# Maximum retry attempts per emoji (0-10, default: 3)
DEFAULT_MAX_RETRIES=3

# How often to update the live progress panel in ms (500-10000, default: 2000)
PROGRESS_INTERVAL_MS=2000

# ────────────────────────────────────────────────────────────────────────────
# Environment
# ────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
